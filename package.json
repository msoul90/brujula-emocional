{
  "name": "brujula-emocional",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "build:js": "node scripts/build-js.js",
    "build:css": "npx tailwindcss@3 -i input.css -o dist/tailwind.css --minify",
    "build:sw": "node scripts/bump-sw-version.js",
    "build": "npm run build:sw && npm run build:js && npm run build:css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "npx serve ."
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2",
    "posthog-js": "^1.374.2",
    "preact": "^10.29.1"
  }
}
