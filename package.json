{
  "name": "brujula-emocional",
  "private": true,
  "scripts": {
    "build:js": "esbuild app.js --bundle --format=iife --outfile=dist/app.bundle.js",
    "build:css": "npx tailwindcss@3 -i input.css -o dist/tailwind.css --minify",
    "build:sw": "node scripts/bump-sw-version.js",
    "build": "npm run build:sw && npm run build:js && npm run build:css",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npx serve ."
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.5"
  }
}
